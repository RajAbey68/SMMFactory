# SMMFactory — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# ── AI Providers (at least one required) ──────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# AI_PROVIDER=openai   # uncomment to force a specific provider

# ── Google Cloud ──────────────────────────────────────────────────
GCS_BUCKET_NAME=marketing-studio-assets
GCS_PROJECT_ID=
GCS_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_ROOT_DIR=Antigravity_Studio_Project
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Meta Ads ──────────────────────────────────────────────────────
META_AD_ACCOUNT_ID=
META_API_TOKEN=
META_BUSINESS_ACCOUNT_ID=

# ── TikTok Ads ────────────────────────────────────────────────────
TIKTOK_AD_ACCOUNT_ID=
TIKTOK_ACCESS_TOKEN=
TIKTOK_BUSINESS_ACCOUNT_ID=

# ── LinkedIn ──────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CAMPAIGN_GROUP_ID=

# ── OpenAI Ads Platform ───────────────────────────────────────────
OPENAI_ADS_API_KEY=
OPENAI_ADS_ACCOUNT_ID=

# ── AdSpyder ──────────────────────────────────────────────────────
ADSPYDER_API_KEY=

# ── Slack ─────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#marketing-studio

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
